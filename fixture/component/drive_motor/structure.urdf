<?xml version="1.0" ?>
<robot name="drive_motor_device">

  <!-- ==================== Stator (Mount) ==================== -->
  <!-- The non-moving part of the motor that attaches to the robot chassis -->
  <link name="mount" />

  <!-- ==================== Motor Joint ==================== -->
  <joint name="motor_joint" type="continuous">
    <parent link="mount" />
    <child link="rotor_link" />
    <!-- Center of rotation. Default to Z-axis alignment for rotational motors -->
    <origin xyz="0 0 0" rpy="0 0 0" />
    <axis xyz="0 0 1" />
  </joint>

  <!-- ==================== Rotor (Spinning Hub/Wheel) ==================== -->
  <link name="rotor_link">
    <visual>
      <!-- The PROTO applies a rotation of (1, 0, 0, 1.5708) to the mesh -->
      <origin xyz="0 0 0" rpy="1.5708 0 0" />
      <geometry>
        <mesh filename="package://meshes/drive_motor.obj" />
      </geometry>
    </visual>
    <collision>
      <!-- The PROTO applies a translation of (0, 0, -0.022) to the bounding cylinder -->
      <origin xyz="0 0 -0.022" rpy="0 0 0" />
      <geometry>
        <cylinder radius="0.11" length="0.08" />
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <!-- From PROTO default mass 0.8 -->
      <mass value="0.8" />
      <!-- Approximate cylinder inertia tensor (m=0.8, r=0.11, h=0.08) -->
      <!-- Ixx/Iyy = 1/12*m*(3*r^2 + h^2) = ~0.0028 -->
      <!-- Izz = 1/2*m*r^2 = ~0.0048 -->
      <inertia ixx="0.0028" ixy="0.0" ixz="0.0" iyy="0.0028" iyz="0.0" izz="0.0048" />
    </inertial>
  </link>

</robot>
