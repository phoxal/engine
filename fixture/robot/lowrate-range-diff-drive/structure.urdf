<?xml version="1.0" ?>
<robot name="RgbdImuDiffDrive">

  <!-- A phantom link located at ground level. -->
  <link name="base_footprint" />

  <!-- Main chassis frame. -->
  <link name="base_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.50 0.30 0.10" />
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <box size="0.50 0.30 0.10" />
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <mass value="4.0" />
      <inertia ixx="0.04" ixy="0.0" ixz="0.0" iyy="0.09" iyz="0.0" izz="0.10" />
    </inertial>
  </link>

  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_footprint" />
    <child link="base_link" />
    <origin xyz="0 0 0.10" rpy="0 0 0" />
  </joint>

  <link name="front_left_wheel_mount" />

  <joint name="front_left_wheel_mount_joint" type="fixed">
    <parent link="base_link" />
    <child link="front_left_wheel_mount" />
    <origin xyz="0.18 0.20 -0.10" rpy="-1.5708 0 0" />
  </joint>

  <link name="front_right_wheel_mount" />

  <joint name="front_right_wheel_mount_joint" type="fixed">
    <parent link="base_link" />
    <child link="front_right_wheel_mount" />
    <origin xyz="0.18 -0.20 -0.10" rpy="1.5708 0 0" />
  </joint>

  <link name="rear_left_wheel_mount" />

  <joint name="rear_left_wheel_mount_joint" type="fixed">
    <parent link="base_link" />
    <child link="rear_left_wheel_mount" />
    <origin xyz="-0.18 0.20 -0.10" rpy="-1.5708 0 0" />
  </joint>

  <link name="rear_right_wheel_mount" />

  <joint name="rear_right_wheel_mount_joint" type="fixed">
    <parent link="base_link" />
    <child link="rear_right_wheel_mount" />
    <origin xyz="-0.18 -0.20 -0.10" rpy="1.5708 0 0" />
  </joint>

  <link name="imu_mount" />

  <joint name="imu_mount_joint" type="fixed">
    <parent link="base_link" />
    <child link="imu_mount" />
    <origin xyz="0 0 0.08" rpy="0 0 0" />
  </joint>

  <link name="front_camera_mount" />

  <joint name="front_camera_mount_joint" type="fixed">
    <parent link="base_link" />
    <child link="front_camera_mount" />
    <origin xyz="0.24 0 0.10" rpy="0 0.2618 0" />
  </joint>

  <link name="front_center_tof_mount" />

  <joint name="front_center_tof_mount_joint" type="fixed">
    <parent link="base_link" />
    <child link="front_center_tof_mount" />
    <origin xyz="0.26 0 0.03" rpy="0 0 0" />
  </joint>

</robot>
